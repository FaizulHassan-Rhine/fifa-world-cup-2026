# Copy to .env.local — never commit real keys.

# Secret: used only by the Vite dev proxy (not exposed to the browser).
# Paste the same key as on https://dashboard.api-football.com (Live Demo).
API_FOOTBALL_KEY=

# apisports = direct v3.football.api-sports.io (default; matches Live Demo).
# rapidapi = only if you subscribed on rapidapi.com, not the dashboard key.
API_FOOTBALL_MODE=apisports

# Legacy RapidAPI env name (still read if API_FOOTBALL_KEY is empty):
# api-football-v1-pkey=

# Optional public id — narrows API tournament fetch on the World Cup page.
# VITE_WORLD_CUP_LEAGUE_ID=
